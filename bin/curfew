#!/usr/bin/env bash
set -euo pipefail

PREFIX_DEFAULT="/usr/local"
CONF="/etc/curfew.conf"

LIBDIR="${CURFEW_LIBDIR:-$PREFIX_DEFAULT/lib/curfew}"
ENFORCER="$LIBDIR/curfew.sh"

SYS_TIMER="/etc/systemd/system/curfew-shutdown.timer"
SYS_SERVICE_SHUT="curfew-shutdown.service"
SYS_SERVICE_ENFORCE="curfew-enforce.service"

USER_UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
USER_TIMER="$USER_UNIT_DIR/curfew-warn.timer"
USER_SERVICE="curfew-warn.service"

OVERRIDE_TMP="/run/curfew.override"
OVERRIDE_PERSIST="/etc/curfew.override"

die(){ echo "curfew: $*" >&2; exit 1; }

valid_hhmm(){ [[ "$1" =~ ^([01][0-9]|2[0-3]):[0-5][0-9]$ ]]; }
require_root(){ [[ "${EUID:-$(id -u)}" -eq 0 ]] || die "must run as root (use sudo)"; }
require_non_root(){ [[ "${EUID:-$(id -u)}" -ne 0 ]] || die "run without sudo (will prompt as needed)"; }

# Load config as shell vars
load_conf() {
  [[ -r "$CONF" ]] || die "missing $CONF"
  # shellcheck disable=SC1090
  source "$CONF"
  : "${WARNING_TIME:?}" "${SHUTOFF_TIME:?}" "${WAKEUP_TIME:?}" "${ENABLED:?}" "${ENFORCE:?}"
  valid_hhmm "$WARNING_TIME" || die "invalid WARNING_TIME=$WARNING_TIME"
  valid_hhmm "$SHUTOFF_TIME" || die "invalid SHUTOFF_TIME=$SHUTOFF_TIME"
  valid_hhmm "$WAKEUP_TIME"  || die "invalid WAKEUP_TIME=$WAKEUP_TIME"
  [[ "$ENABLED" =~ ^[01]$ ]] || die "ENABLED must be 0/1"
  [[ "$ENFORCE" =~ ^[01]$ ]] || die "ENFORCE must be 0/1"
}

# Atomic write helper
atomic_write() {
  local path="$1" mode="$2"
  local tmp
  tmp="$(mktemp "/tmp/$(basename "$path").tmp.XXXXXX")"
  cat >"$tmp"
  chmod "$mode" "$tmp"
  sudo mv -f "$tmp" "$path"
}

# Edit/append KEY=VALUE in /etc/curfew.conf
set_kv() {
  local key="$1" val="$2"
  if sudo grep -qE "^${key}=" "$CONF"; then
    sudo sed -i -E "s|^${key}=.*$|${key}=${val}|" "$CONF"
  else
    echo "${key}=${val}" | sudo tee -a "$CONF" >/dev/null
  fi
}

to_minutes() {
  local hh="${1%:*}" mm="${1#*:}"
  echo $((10#$hh * 60 + 10#$mm))
}

in_window_wrap() {
  local now="$1" start="$2" end="$3"
  if (( start < end )); then
    (( now >= start && now < end ))
  else
    (( now >= start || now < end ))
  fi
}

# Determine which user to manage user units for when running under sudo
target_user_info() {
  local u uid home
  u="${SUDO_USER:-}"
  if [[ -z "$u" || "$u" == "root" ]]; then
    # not under sudo; use current user
    u="$(id -un)"
  fi
  uid="$(id -u "$u")"
  home="$(getent passwd "$u" | cut -d: -f6)"
  echo "$u" "$uid" "$home"
}

user_systemctl() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    systemctl --user "$@"
    return
  fi
  local u uid home
  read -r u uid home < <(target_user_info)
  local xdg="/run/user/$uid"
  [[ -d "$xdg" ]] || die "no XDG runtime dir at $xdg (is user $u logged in?)"
  XDG_RUNTIME_DIR="$xdg" runuser -u "$u" -- systemctl --user "$@"
}

ensure_user_unit_dir() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    mkdir -p "$HOME/.config/systemd/user"
    return
  fi
  local u uid home
  read -r u uid home < <(target_user_info)
  runuser -u "$u" -- mkdir -p "$home/.config/systemd/user"
}

generate_system_timer() {
  load_conf
  atomic_write "$SYS_TIMER" 0644 <<EOF
[Unit]
Description=Daily curfew shutdown at ${SHUTOFF_TIME}

[Timer]
OnCalendar=*-*-* ${SHUTOFF_TIME}:00
Persistent=false

[Install]
WantedBy=timers.target
EOF
}

generate_user_timer() {
  load_conf
  ensure_user_unit_dir
  local path
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    path="$HOME/.config/systemd/user/curfew-warn.timer"
    cat >"$path" <<EOF
[Unit]
Description=Daily curfew warning at ${WARNING_TIME}

[Timer]
OnCalendar=*-*-* ${WARNING_TIME}:00
Persistent=false

[Install]
WantedBy=timers.target
EOF
    return
  fi
  local u uid home
  read -r u uid home < <(target_user_info)
  path="$home/.config/systemd/user/curfew-warn.timer"
  # write as the user (not root) so permissions are normal
  runuser -u "$u" -- bash -c "cat >'$path' <<'EOF'
[Unit]
Description=Daily curfew warning at ${WARNING_TIME}

[Timer]
OnCalendar=*-*-* ${WARNING_TIME}:00
Persistent=false

[Install]
WantedBy=timers.target
EOF"
}

apply_all() {
  [[ -x "$ENFORCER" ]] || die "missing enforcer script at $ENFORCER"

  generate_system_timer
  generate_user_timer

  sudo systemctl daemon-reload

  # Ensure enforce-on-boot is enabled (behavior controlled by ENFORCE=0/1)
  sudo systemctl enable --now "$SYS_SERVICE_ENFORCE"

  load_conf
  if [[ "$ENABLED" -eq 1 ]]; then
    sudo systemctl enable --now curfew-shutdown.timer
  else
    sudo systemctl disable --now curfew-shutdown.timer || true
  fi

  # user timer enable/disable is user-scoped; we try best-effort
  if user_systemctl daemon-reload 2>/dev/null; then
    if [[ "$ENABLED" -eq 1 ]]; then
      user_systemctl enable --now curfew-warn.timer || true
    else
      user_systemctl disable --now curfew-warn.timer || true
    fi
  fi
}

cmd_status() {
  load_conf
  echo "Config: $CONF"
  echo "  WARNING_TIME=$WARNING_TIME"
  echo "  SHUTOFF_TIME=$SHUTOFF_TIME"
  echo "  WAKEUP_TIME=$WAKEUP_TIME"
  echo "  ENABLED=$ENABLED"
  echo "  ENFORCE=$ENFORCE"
  echo
  echo "Overrides:"
  echo "  $OVERRIDE_TMP: $( [[ -f $OVERRIDE_TMP ]] && echo present || echo absent )"
  echo "  $OVERRIDE_PERSIST: $( [[ -f $OVERRIDE_PERSIST ]] && echo present || echo absent )"
  echo
  echo "System timers:"
  systemctl list-timers --all | grep -E 'curfew-shutdown\.timer' || true
  echo
  echo "User timers (current user):"
  systemctl --user list-timers --all 2>/dev/null | grep -E 'curfew-warn\.timer' || true
}

cmd_check() {
  load_conf
  local now_hhmm now start end
  now_hhmm="$(date +%H:%M)"
  now="$(to_minutes "$now_hhmm")"
  start="$(to_minutes "$SHUTOFF_TIME")"
  end="$(to_minutes "$WAKEUP_TIME")"

  if in_window_wrap "$now" "$start" "$end"; then
    echo "IN curfew window: now=$now_hhmm window=${SHUTOFF_TIME}-${WAKEUP_TIME}"
  else
    echo "OUTSIDE curfew window: now=$now_hhmm window=${SHUTOFF_TIME}-${WAKEUP_TIME}"
  fi
}

cmd_notify() {
  # user session: show notification
  load_conf
  if [[ -f "$OVERRIDE_TMP" || -f "$OVERRIDE_PERSIST" ]]; then
    notify-send "Curfew" "Override is active. (No shutdown/enforce.)"
    exit 0
  fi
  notify-send "Curfew" "Shutdown scheduled at ${SHUTOFF_TIME}. Override: sudo curfew override on"
}

usage() {
  cat <<'EOF'
Usage:
  curfew status
  curfew check
  curfew notify

  curfew apply
  sudo curfew set warning HH:MM
  sudo curfew set shutoff HH:MM
  sudo curfew set wakeup  HH:MM
  curfew enable | disable
  sudo curfew enforce on | off
  sudo curfew override on | off
  sudo curfew override persist-on | persist-off

  curfew user-enable | user-disable   (enable/disable the user warning timer)
EOF
}

main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    status) cmd_status ;;
    check) cmd_check ;;
    notify) cmd_notify ;;

    apply)
      require_non_root
      apply_all
      ;;

    set)
      require_root
      [[ $# -eq 2 ]] || die "usage: sudo curfew set {warning|shutoff|wakeup} HH:MM"
      local which="$1" t="$2"
      valid_hhmm "$t" || die "invalid time '$t' (expected HH:MM)"
      case "$which" in
        warning) set_kv WARNING_TIME "$t" ;;
        shutoff) set_kv SHUTOFF_TIME "$t" ;;
        wakeup)  set_kv WAKEUP_TIME "$t" ;;
        *) die "unknown field '$which'" ;;
      esac
      apply_all
      ;;

    enable)
      require_non_root
      set_kv ENABLED 1
      apply_all
      ;;

    disable)
      require_non_root
      set_kv ENABLED 0
      apply_all
      ;;

    enforce)
      require_root
      case "${1:-}" in
        on)  set_kv ENFORCE 1; apply_all ;;
        off) set_kv ENFORCE 0; apply_all ;;
        *) die "usage: sudo curfew enforce {on|off}" ;;
      esac
      ;;

    override)
      require_root
      case "${1:-}" in
        on) sudo touch "$OVERRIDE_TMP" ;;
        off) sudo rm -f "$OVERRIDE_TMP" ;;
        persist-on) sudo touch "$OVERRIDE_PERSIST" ;;
        persist-off) sudo rm -f "$OVERRIDE_PERSIST" ;;
        *) die "usage: sudo curfew override {on|off|persist-on|persist-off}" ;;
      esac
      ;;

    user-enable)
      systemctl --user daemon-reload
      systemctl --user enable --now curfew-warn.timer
      ;;

    user-disable)
      systemctl --user disable --now curfew-warn.timer || true
      ;;

    ""|-h|--help|help) usage ;;
    *) die "unknown command '$cmd' (try: curfew help)" ;;
  esac
}

main "$@"
